{
  "name": "@toon-tools/fetch",
  "version": "1.0.0",
  "description": "Framework-agnostic TOON fetch wrapper for TanStack Query, SWR, and standalone use",
  "keywords": [
    "content-negotiation",
    "fetch",
    "llm",
    "swr",
    "tanstack-query",
    "toon"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nkootstra/toon-tools.git",
    "directory": "packages/fetch"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@toon-tools/core": "workspace:^",
    "effect": "4.0.0-beta.33"
  },
  "devDependencies": {
    "@effect/vitest": "4.0.0-beta.33",
    "tsup": "^8.5.1",
    "vitest": "^4.1.0"
  }
}
