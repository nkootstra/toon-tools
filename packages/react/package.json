{
  "name": "@toon-tools/react",
  "version": "1.1.0",
  "description": "React hooks for TOON data fetching with TanStack Query",
  "keywords": [
    "content-negotiation",
    "hooks",
    "llm",
    "react",
    "tanstack-query",
    "toon"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nkootstra/toon-tools.git",
    "directory": "packages/react"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@toon-tools/fetch": "workspace:^"
  },
  "devDependencies": {
    "@effect/vitest": "4.0.0-beta.43",
    "@tanstack/react-query": "^5.96.1",
    "@testing-library/react": "^16.3.2",
    "@toon-format/toon": "^2.1.0",
    "@types/react": "^19.0.0",
    "jsdom": "^29.0.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tsup": "^8.5.1",
    "vitest": "^4.1.2"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.0.0",
    "effect": ">=4.0.0-beta.1",
    "react": "^18.0.0 || ^19.0.0"
  }
}
