{
  "name": "@toon-tools/hono",
  "version": "0.1.0",
  "description": "Hono middleware for TOON content negotiation",
  "keywords": [
    "content-negotiation",
    "hono",
    "llm",
    "middleware",
    "toon"
  ],
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@toon-tools/core": "workspace:*"
  },
  "devDependencies": {
    "@toon-format/toon": "^2.1.0",
    "hono": "^4.12.8",
    "tsup": "^8.5.1",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "hono": "^4.0.0"
  }
}
