{
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/nkootstra/toon-tools.git"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "test:integration": "vitest run tests/integration",
    "version:set": "pnpm -r exec npm pkg set version=$VERSION"
  },
  "devDependencies": {
    "@effect/vitest": "4.0.0-beta.43",
    "@tanstack/react-query": "^5.96.1",
    "@testing-library/react": "^16.3.2",
    "@toon-format/toon": "^2.1.0",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "effect": "4.0.0-beta.43",
    "elysia": "^1.4.28",
    "hono": "^4.12.9",
    "jsdom": "^29.0.1",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.58.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "turbo": "^2.9.3",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "packageManager": "pnpm@10.18.3",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
